#!/bin/sh
#
# pngdiff.sh <ok_png> <png> <diff_png>
#
# compare produced PNG to a reference file, using ImageMagick.
#
# Ref: ImageMagick Comparing:
#       <http://www.imagemagick.org/Usage/compare/>
#
# Recommended:
#       ImageMagick >= 6.4.0    (works crippled with IM 6.2.x)
#

OK_PNG=$1
PNG=$2
DIFF_PNG=$3

if [ -f /usr/bin/magick ]; then
    COMPARE="/usr/bin/magick compare"
    CONVERT="/usr/bin/magick"
else
    COMPARE=/usr/bin/convert
    CONVERT=/usr/bin/convert
fi

if [[ $CI == "" ]]; then
  COL_RED="$(tput setaf 1)"
  COL_GREEN="$(tput setaf 2)"
  COL_YELLOW="$(tput setaf 3)"
  COL_NORM="$(tput setaf 7)"
  COL_BOLD="$(tput bold)"
  COL_OFF="$(tput sgr0)"
fi

if [ \! -f $PNG ]; then
    echo "${COL_RED}*** FAILED:${COL_OFF} '${PNG}' not created"
    exit -1
fi

# Locate the comparison tools next to this script, falling back to PATH.
here=$(dirname $0)
smartimagediff_psnr=$here/smartimagediff_psnr
[ -x "$smartimagediff_psnr" ] || smartimagediff_psnr=smartimagediff_psnr
smartimagediff=$here/smartimagediff
[ -x "$smartimagediff" ] || smartimagediff=smartimagediff

# Create the visual difference file.
#
# Shadow mode: PSNR (below) stays the headline verdict and exit code, but when
# the structural, anti-aliasing-aware comparator is available it writes the
# diff image -- the expected frame faded to faint grayscale with the real
# changes painted red and boxed, which lands the eye on a regression instead of
# the equalized full-frame of edge noise the DIFFERENCE+contrast-stretch
# produced. Its verdict is captured for the [sid:...] tag and the
# SHADOW-DISAGREE marker added to the verdict lines below.
SID_LABEL=SKIP
SID_INFO=""
SID_PASS=""
if command -v "$smartimagediff" >/dev/null 2>&1; then
    SID_OUT=$("$smartimagediff" $OK_PNG $PNG $DIFF_PNG 2>&1)
    SID_RC=$?
    SID_INFO=$(echo "$SID_OUT" | head -1)
    case $SID_RC in
        0) SID_LABEL=OK;    SID_PASS=1 ;;
        1) SID_LABEL=FAIL;  SID_PASS=0 ;;
        *) SID_LABEL=ERROR             ;;
    esac
else
    # Legacy fallback: DIFFERENCE composite, contrast-stretched.
    composite $OK_PNG $PNG -compose DIFFERENCE png:- | \
        $CONVERT - -contrast-stretch 0 $DIFF_PNG
fi

# Tag appended to every verdict line, plus a disagreement marker printed when
# PSNR and structural reach opposite pass/fail conclusions (the greppable
# signal for comparing the two on a real test run). $1 = 1 if PSNR passes.
sid_tag="[sid:$SID_LABEL${SID_INFO:+ $SID_INFO}]"
disagree() {
    [ "$SID_LABEL" != SKIP ] && [ "$SID_LABEL" != ERROR ] && \
        [ -n "$SID_PASS" ] && [ "$SID_PASS" != "$1" ] && \
        printf '%s' "${COL_BOLD}SHADOW-DISAGREE${COL_OFF} "
}

# Get measurement of the difference
#
#   Metric can be:
#       AE (Absolute Error):    Number of pixels that were different, after applying fuzziness factor
#       PAE (Peak Absolute Error)
#       PSNR (Peak Signal/Noise Ratio): dB (1..inf) 1=all different, 20=differences 1/100 of maximum
#       MAE (Mean Absolute Error)
#       MSE (Mean Squared Error)
#       RMSE sqrt of MSE
#

# Note: '-metric AE' and '-fuzz n%' would be a good combo, but requires IM >= 6.4.3
#
#V="$($COMPARE 2>&1 -metric AE -fuzz 5% ${OK_PNG} ${PNG} ${DIFF_PNG})"

# Note: IM 6.4.x outputs just the PSNR number (i.e. 22.432) but 6.2.8 outputs
#	"22.432 dB\n300,300,PNG" which is... troublesome
#
#V="$($COMPARE 2>&1 -metric PSNR ${OK_PNG} ${PNG} ${DIFF_PNG} | head -1 | sed "-es/ dB//")"

# Note: IM 6.2.x seems to have trouble with opacity; gives many
#       "image opacity differs" errors; 6.4.x gives not.
#

#V=$(($COMPARE 2>&1 -metric PSNR ${OK_PNG} ${PNG} /dev/null | head -1 | sed "-es/ dB//") || exit 255)

# Cut non-decimal values (error string) out
#
# Note: Need to use 'bc' to handle non-integer comparisons. 'expr' would handle
#       decimals as string comparison, i.e. 'expr "7.1" \> 10' --> 1.
#
#echo "<<$V232321>>" | sed -es/[1-9.]//g
#echo "<<$V>>" | sed -es/[1-9.]//g
#
#if [ -n $(echo "$V" | sed -es/[1-9.]//g) ]; then
#    echo "${COL_RED}FAIL:${COL_OFF} $V"
#    exit 100

# HACK: A real hack. Did not get the above code to work.
#

# PSNR verdict (authoritative during the transition; smartimagediff_psnr was
# located next to this script above).
result=$($smartimagediff_psnr $OK_PNG $PNG 2>&1 | head -1)
V=$(echo $result | awk '/^PSNR:/ { print $2 }')
case "$V" in
    inf)
        echo "$(disagree 1)${COL_GREEN}OK:${COL_OFF} $sid_tag"
        exit 0
        ;;
    [0-9\.][0-9\.]*)
        if [ $(echo "$V >= 50" | bc) = 1 ]; then
            echo "$(disagree 1)${COL_GREEN}OK:${COL_OFF} PSNR >= 50dB ($V dB) $sid_tag"
            exit 0
        elif [ $(echo "$V >= 20" | bc) = 1 ]; then
            echo "$(disagree 1)${COL_YELLOW}WARNING:${COL_OFF} 20dB <= PSNR < 50dB ($V dB) $sid_tag"
            exit 0
        elif [ $(echo "$V >= 0" | bc) = 1 ]; then
            echo "$(disagree 0)${COL_RED}FAIL:${COL_OFF} PSNR < 20dB ($V dB) $sid_tag"
            exit 100
        fi
        ;;
    *)
        echo "${COL_RED}FAIL:${COL_OFF} $result $sid_tag"
        exit 100
        ;;
esac

